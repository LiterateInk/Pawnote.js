  "license": "GPL-3.0-or-later",
  "homepage": "https://pawnote.docs.literate.ink/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LiterateInk/Pawnote.js.git"
  },
  "bugs": {
    "url": "https://github.com/LiterateInk/Pawnote.js/issues"
  },
  "keywords": [
    "pronote",
    "wrapper",
    "api"
  ],
