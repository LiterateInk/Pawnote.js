  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup"
  },
  "dependencies": {
    "@literate.ink/utilities": "1.0.0-10641118381.1",
    "html-entities": "^2.5.2",
    "node-forge": "^1.3.1",
    "pako": "^2.1.0",
    "schwi": "^0.5.0"
  },
  "devDependencies": {
    "@inquirer/prompts": "^4.3.3",
    "@types/bun": "^1.2.19",
    "@types/node-forge": "^1.3.11",
    "@types/pako": "^2.0.3",
    "@vexcited/eslint-config": "^0.1.1",
    "dotenv": "^17.2.1",
    "eslint": "^9.32.0",
    "jiti": "^2.5.1",
